# Aztec testnet config for the hybrid submission harness.
# Copy to `.env` (gitignored) and fill in. NEVER commit real keys.

# Testnet node RPC (v5.0.0-rc.2, matches this repo's pin).
AZTEC_NODE_URL=https://v5.testnet.rpc.aztec-labs.com

# SponsoredFPC pays fees so you don't need to bridge fee-juice.
SPONSORED_FPC_ADDRESS=0x1969946536f0c09269e2c75e414eef4e21a76e763c5514125208db33d7d944d7

# Where proving runs: "host" (native lib on this machine) or "adb" (on device).
BRIDGE=host

# --- Account (SECRETS — env only, never commit) ---
# 32-byte hex field elements / signing key for the testnet account.
# Generate fresh values; keep them out of git.
ACCOUNT_SECRET=0x...
ACCOUNT_SALT=0x...
ACCOUNT_SIGNING_KEY=0x...   # 32-byte hex (secp256r1 private key)

# Optional: recipient for the private transfer (defaults to self-transfer).
# RECIPIENT_ADDRESS=0x...

# --- Native prover bridge (host) ---
# PROVER_BIN=../target/release/bb-chonk-prove
# SRS_G1=../android/app/src/main/assets/srs/bn254_g1.dat
# SRS_G2=../android/app/src/main/assets/srs/bn254_g2.dat
# SRS_GRUMPKIN=../android/app/src/main/assets/srs/grumpkin_g1.dat

# --- Native prover bridge (adb / on-device) ---
# ADB_SERIAL=emulator-5554
# DEVICE_PROVER_DIR=/data/local/tmp/aztec-prover
